void drawPriceTask(void *parameter) {
  if (isRenderingPrice) {
    vTaskDelete(NULL);
    return;
  }

  isRenderingPrice = true;

  String priceStr = *((String *)parameter);
  delete (String *)parameter;

  // Debugging check
